{
  "name": "@endge/configurator",
  "type": "module",
  "version": "1.0.3",
  "version_updated": "22.04.2026",
  "private": false,
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "run-p dev:libs dev:app",
    "devsafe": "rm -rf node_modules/.vite && run-p dev:libs dev:app",
    "dev:app": "vite",
    "dev:libs": "pnpm --filter @endge/raph --filter @endge/utils --filter @endge/core --filter @endge/vue --filter @endge/shadcn-vue --parallel --if-present dev",
    "build": "run-s build:libs 'build-only {@}' --",
    "build:libs": "pnpm --filter @endge/codegen --filter @endge/raph --filter @endge/utils --filter @endge/core --filter @endge/vue --filter @endge/shadcn-vue --workspace-concurrency=1 build",
    "build-only": "vite build",
    "codegen:listen": "endge-codegen listen",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "lint-check": "eslint .",
    "format": "prettier \"{src,packages}/**/*.{js,cjs,mjs,jsx,ts,tsx,mts,cts,vue}\" --write",
    "lint-fix": "eslint . --fix && pnpm format && eslint . --fix",
    "fix": "pnpm lint-fix"
  },
  "dependencies": {
    "@endge/codegen": "^0.1.0",
    "@endge/core": "^1.2.6",
    "@endge/raph": "^3.0.1",
    "@endge/shadcn-vue": "workspace:*",
    "@endge/utils": "^0.24.2",
    "@endge/vue": "^0.23.2",
    "@formatjs/intl-durationformat": "^0.7.6",
    "@lucide/lab": "^0.1.2",
    "@revolist/vue3-datagrid": "^4.19.4",
    "@tabler/icons-webfont": "^3.36.1",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue/compiler-dom": "^3.5.24",
    "@vue/devtools-api": "^8.0.3",
    "@vueuse/core": "^13.9.0",
    "@vueuse/integrations": "^13.9.0",
    "@vueuse/router": "^13.9.0",
    "axios": "^1.13.2",
    "class-transformer": "^0.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "highlight.js": "^11.11.1",
    "idb": "^8.0.3",
    "iso8601-duration": "^2.1.3",
    "ky": "^1.14.0",
    "lodash": "^4.17.21",
    "lucide-vue-next": "^0.544.0",
    "markdown-it": "^14.1.1",
    "monaco-editor": "^0.55.1",
    "object-hash": "^3.0.0",
    "pinia": "^2.1.7",
    "prettier": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "reka-ui": "^2.6.0",
    "tailwind-merge": "^3.3.1",
    "ts-luxon": "^6.2.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "vaul-vue": "^0.4.1",
    "vue": "^3.5.24",
    "vue-i18n": "~11.1.12",
    "vue-json-pretty": "^2.6.0",
    "vue-router": "^4.6.3",
    "vue-sonner": "^2.0.9",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@intlify/eslint-plugin-vue-i18n": "~4.1.0",
    "@tailwindcss/vite": "^4.1.17",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.19.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.1",
    "npm-run-all2": "^8.0.4",
    "sass-embedded": "^1.93.3",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.3",
    "vite": "^7.2.2",
    "vite-plugin-vue-devtools": "^8.0.3",
    "vue-tsc": "^3.1.3"
  }
}
